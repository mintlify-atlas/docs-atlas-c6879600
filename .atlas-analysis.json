  "keyFeatures": [
    "Voice-to-text journaling with ElevenLabs Scribe transcription",
    "AI-powered story analysis and cognitive insights via Google Gemini",
    "Client-side encrypted local vault with AES-256-GCM encryption",
    "Blockchain permanence with NFT minting on Base L2",
    "Chainlink CRE verifiable AI metrics with privacy-preserving attestation",
    "Social features with likes, tips, follows, and paywall monetization",
    "$STORY token economy with creator rewards",
    "Dual authentication: Web3 wallet + Google OAuth",
    "IPFS storage via Pinata for decentralized file persistence",
    "React Native mobile app (iOS/Android)"
  ],
  "publicApiSurface": [
    "POST /api/ai/transcribe - Convert audio to text",
    "POST /api/ai/enhance - AI text enhancement",
    "POST /api/ai/analyze - Extract story metadata and insights",
    "POST /api/ai/reflection - Generate weekly reflections",
    "GET /api/auth/nonce - Generate wallet signature nonce",
    "POST /api/auth/login - Wallet authentication",
    "POST /api/journal/save - Save story to database",
    "GET /api/stories/[storyId]/metadata - Get story insights",
    "POST /api/social/like - Like/unlike stories",
    "POST /api/social/follow - Follow/unfollow users",
    "POST /api/tip - Send $STORY tokens to creators",
    "POST /api/paywall - Unlock premium content",
    "POST /api/cre/trigger - Trigger Chainlink CRE verification",
    "GET /api/cre/check - Check verification status",
    "useVault() - Local vault encryption hook",
    "useLocalStories() - Encrypted IndexedDB CRUD",
    "useVerifiedMetrics() - CRE metrics polling hook",
    "useIStoryToken() - ERC20 token interactions",
    "useStoryNFT() - NFT minting and management",
    "useStoryProtocol() - Tips and paywall contract"
  ]
}
